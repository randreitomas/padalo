{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@padalo/shared": [
        "../../packages/shared/src/index.ts"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-dashboard-build/types/**/*.ts",
    ".next-launch-polish-build/types/**/*.ts",
    ".next-production/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-header-tighten-build/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
