# Shared
APP_ENV=development

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# API
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Neon PostgreSQL
# Example format:
# DATABASE_URL=postgresql+psycopg://user:password@ep-example.us-east-1.aws.neon.tech/padalo?sslmode=require
DATABASE_URL=

# When DATABASE_URL is blank, development starts this deterministic SQLite Santos Family demo.
# Production requires DATABASE_URL and never uses this fallback.
LOCAL_DEMO_MODE=true
LOCAL_DEMO_DATABASE_URL=sqlite:///./.padalo-demo.sqlite3

# OpenAI credentials are required only when enabling the Phase 4 agent.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Enable only in an isolated hackathon demo deployment. Keep this value server-side.
DEMO_RESET_ENABLED=false
DEMO_RESET_TOKEN=
